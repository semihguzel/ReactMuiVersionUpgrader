{
  "name": "react-mui-version-upgrader",
  "version": "1.0.0",
  "description": "MUI automatic migration tool (v4→v5, v5→v6, v6→v7, v7→v8/v9)",
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "mui-upgrader": "./bin/cli.js"
  },
  "scripts": {
    "start": "node bin/cli.js",
    "test": "node --experimental-vm-modules node_modules/.bin/jest"
  },
  "keywords": ["mui", "material-ui", "migration", "v4", "v5", "codemod"],
  "license": "MIT",
  "dependencies": {
    "jscodeshift": "^17.1.2",
    "commander": "^12.1.0",
    "chalk": "^5.4.1",
    "fast-glob": "^3.3.3",
    "inquirer": "^9.3.7"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "@jest/globals": "^29.7.0"
  }
}
